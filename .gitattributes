# Enforce deterministic repository line endings across all platforms.
# Prevents Windows-specific LF/CRLF staging ambiguity from obscuring diffs and audits.

* text=auto
.gitattributes text eol=lf

*.sql  text eol=lf
*.py   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.svg  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

*.png binary
*.ico binary
